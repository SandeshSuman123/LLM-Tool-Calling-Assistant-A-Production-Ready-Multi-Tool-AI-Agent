# ------------------------------------------------------------------
# Copy this file to `.env` and fill in your real values.
# `.env` is never committed to git (see .gitignore).
# ------------------------------------------------------------------

# Required: get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: override the OpenRouter base URL (rarely needed).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: any OpenRouter model ID that supports tool calling.
# Free examples: qwen/qwen-2.5-72b-instruct:free
#                meta-llama/llama-3.1-8b-instruct:free
#                google/gemma-2-9b-it:free
MODEL_NAME=qwen/qwen-2.5-72b-instruct:free

# Optional: only needed if you swap the weather tool to OpenWeatherMap.
OPENWEATHER_API_KEY=

# Optional: only needed if you swap the search tool to a paid provider
# such as Tavily or Serper.
SEARCH_API_KEY=

# --- Runtime behaviour --------------------------------------------
MAX_TOOL_ITERATIONS=6
REQUEST_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
ENABLE_STREAMING=true

# --- OpenRouter attribution headers (optional but recommended) -----
APP_NAME=ai-personal-assistant
APP_URL=https://github.com/your-username/ai-personal-assistant
